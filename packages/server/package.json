{
  "name": "@accord-kit/server",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "accord-server": "./bin/accord-server.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build",
    "start": "node bin/accord-server.mjs",
    "start:verbose": "node bin/accord-server.mjs --verbose"
  },
  "dependencies": {
    "@accord-kit/core": "workspace:*",
    "@hocuspocus/extension-sqlite": "^4.0.0",
    "@hocuspocus/server": "^4.0.0",
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  }
}
